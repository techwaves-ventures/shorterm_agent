# Copy to .env and fill in real values. .env is gitignored. Never commit secrets.

# --- FurnishedFinder (operator tenant only; other tenants connect in the UI) ---
# The operator's FurnishedFinder login email (OTP login — no password).
FF_USERNAME=

# Name that auto-drafted replies sign off with (the operator host's name).
HOST_NAME=

# Optional webhook for notifications (Slack/Discord/etc). Leave blank to disable.
NOTIFY_WEBHOOK_URL=

# Set to 1 to run headless (no visible window). Default 0 = visible real browser.
HEADLESS=0
# Optional Playwright proxy for browser-host workers. Useful when the target site
# blocks datacenter/server egress. Leave blank for direct browser traffic.
BROWSER_PROXY_SERVER=
BROWSER_PROXY_USERNAME=
BROWSER_PROXY_PASSWORD=

# Anthropic API key — required for the auto-responder agent (drafting replies).
# Get one at https://console.anthropic.com/. Leave blank to disable drafting.
ANTHROPIC_API_KEY=

# --- Reply channels ----------------------------------------------------------
# Which channels fire when you click Send. Default sends on both.
# Drop "email" to reply on the platform only.
REPLY_CHANNELS=platform,email

# Email (SMTP) for the email reply channel. Gmail: use an App Password for
# SMTP_PASS (not your account password). FROM_EMAIL defaults to SMTP_USER,
# then FF_USERNAME.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

# --- Auth / multi-tenant -----------------------------------------------------
# Secret used to sign login session cookies. REQUIRED — the dashboard won't
# start without it. Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# Operator login (tenant 1 — the original single-user account, owns all existing
# data). On first run the dashboard creates this user from the values below.
# Afterwards, change the password with:  python manage.py set-password <email>
OPERATOR_EMAIL=
OPERATOR_PASSWORD=
# Public signup is closed by default. Set to 1 only when self-serve signup is
# intentionally open; otherwise visitors use the landing-page contact form.
PUBLIC_SIGNUP_ENABLED=
# Fernet key encrypting tenants' FurnishedFinder email at rest. REQUIRED to let
# tenants connect their FF account (the /connect flow). Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Losing/changing this key makes stored FF emails undecryptable (tenants reconnect).
FF_CRED_KEY=

# --- Billing (Stripe) --------------------------------------------------------
# Leave STRIPE_SECRET_KEY blank to run billing in safe DEMO mode: "subscribing"
# marks the tenant as Pilot (demo) with no live charge. Set the keys below to
# enable real Checkout + the customer portal + webhooks.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
# Public base URL for Stripe redirect callbacks, e.g. https://app.example.com
PUBLIC_BASE_URL=

# --- Storage / deployment ----------------------------------------------------
# Two backends, auto-selected: set DATABASE_URL for hosted Postgres (required on
# serverless like Vercel, where SQLite can't persist), otherwise SQLite is used.
#
# Hosted Postgres (Neon / Vercel Postgres / Supabase). When set, the app ignores
# SQLITE_PATH and stores everything here. Include sslmode=require for most hosts:
#   postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=
# SQLite DB file location (used only when DATABASE_URL is blank). On a disk-based
# host point this at a mounted persistent disk (e.g. /var/data/leads.db).
SQLITE_PATH=

# Demo tenant credentials created by `python manage.py seed-demo` (optional).
DEMO_EMAIL=demo@shorterm.test
DEMO_PASSWORD=
# Set to 1 to auto-seed the demo tenant on first boot (handy on Vercel, where
# running a one-off CLI is awkward). Idempotent — only seeds if it doesn't exist.
SEED_DEMO_ON_BOOT=

# --- Dashboard bind ----------------------------------------------------------
# Local dev keeps loopback-only. On a hosted service set DASHBOARD_HOST=0.0.0.0
# (the platform terminates TLS in front of the app). $PORT is provided by the host.
DASHBOARD_HOST=127.0.0.1
# Avoid 5000 on macOS — AirPlay Receiver binds ::1:5000 and steals localhost.
DASHBOARD_PORT=5050
